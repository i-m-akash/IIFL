{
  "name": "dynamicbackend",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply verbalyze-d1 --local",
    "db:migrate:remote": "wrangler d1 migrations apply verbalyze-d1 --remote",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.14",
    "jose": "^6.1.3",
    "papaparse": "^5.5.3",
    "postgres": "^3.4.9",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260123.0",
    "@types/papaparse": "^5.5.2",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5.9.3",
    "wrangler": "^4.83.0"
  }
}
